{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug FastAPI Agent (Local)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app:app",
        "--host", "0.0.0.0",
        "--port", "8000",
        "--reload"
      ],
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "SKIP_AUTH": "true"
      },
      "jinja": true,
      "justMyCode": false,
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Debug Unit Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "tests/unit/",
        "-v",
        "--tb=short"
      ],
      "cwd": "${workspaceFolder}",
      "justMyCode": false
    },
    {
      "name": "Debug Integration Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "tests/integration/",
        "-v",
        "--tb=short"
      ],
      "envFile": "${workspaceFolder}/.env",
      "cwd": "${workspaceFolder}",
      "justMyCode": false
    }
  ]
}
